# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Campus Lost & Found

# Insforge Backend
INSFORGE_PROJECT_ID=your_insforge_project_id
INSFORGE_API_KEY=your_insforge_api_key
DATABASE_URL=postgresql://user:password@localhost:5432/campus_lost_found

# AI Engine (FastAPI)
FASTAPI_ENV=development
FASTAPI_PORT=8000
LOG_LEVEL=info

# Railway Deployment
RAILWAY_ENVIRONMENT=production
CUSTOM_DOMAIN=lostandfound.sewedy.edu.eg

# Optional
ENABLE_CLASSIFIER=true
ENABLE_BILINGUAL=false
ENABLE_IMAGE_UPLOAD=false

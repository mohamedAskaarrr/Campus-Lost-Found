# Frontend (Vite)
# Backend (FastAPI) base URL
VITE_API_BASE_URL=http://localhost:8000

# Insforge DB REST API (public endpoint)
VITE_INSFORGE_DB_BASE_URL=https://<your-appkey>.<region>.insforge.app/api/db

# Insforge API key (note: VITE_ vars are embedded into the built frontend)
# Use only if this key is intended to be public.
VITE_INSFORGE_DB_KEY=
